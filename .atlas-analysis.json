  "keyFeatures": [
    "Real-time dashboard with analytics and Command Center view",
    "Union and member management with document uploads",
    "Complete loan lifecycle management (draft to completion)",
    "Repayment tracking with multiple payment methods",
    "Role-based access control (Admin, Supervisor, Credit Officer)",
    "Supervisor reporting and analytics",
    "Automated backups to Cloudinary",
    "Maintenance mode for safe deployments",
    "Audit logging and activity tracking"
  ],
  "publicApiSurface": [
    "POST /api/auth/login - Authenticate user",
    "POST /api/auth/logout - End user session",
    "POST /api/auth/forgot-password - Request password reset",
    "GET /api/unions - List all unions",
    "POST /api/unions - Create new union",
    "PUT /api/unions/:id - Update union",
    "DELETE /api/unions/:id - Delete union",
    "GET /api/union-members - List union members",
    "POST /api/union-members - Create union member",
    "PUT /api/union-members/:id - Update member",
    "DELETE /api/union-members/:id - Delete member",
    "GET /api/loans - List loans",
    "POST /api/loans - Create loan",
    "PUT /api/loans/:id - Update loan",
    "PUT /api/loans/:id/approve - Approve loan",
    "PUT /api/loans/:id/status - Update loan status",
    "GET /api/repayments - List repayments",
    "POST /api/repayments - Create repayment",
    "PUT /api/repayments/:id - Update repayment",
    "GET /api/supervisor-reports - Get supervisor reports",
    "GET /api/settings - Get system settings",
    "PUT /api/settings - Update system settings",
    "POST /api/backup - Create backup",
    "GET /api/health - Health check endpoint"
  ]
